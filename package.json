{
  "name": "iobroker.ntfy-client",
  "version": "0.1.4",
  "description": "Unofficial ntfy.sh client adapter for ioBroker",
  "author": {
    "name": "lubepi"
  },
  "homepage": "https://github.com/lubepi/ioBroker.ntfy-client",
  "license": "MIT",
  "keywords": [
