  "dependencies": {
    "@iobroker/adapter-core": "^3.3.2",
    "axios": "^1.17.0",
    "eventsource": "^4.1.0"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.2.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.2.0",
