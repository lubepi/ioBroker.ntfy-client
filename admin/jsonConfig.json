{
  "i18n": true,
  "type": "tabs",
  "items": {
    "mainTab": {
      "type": "panel",
      "label": "Connection",
      "items": {
        "_serverHeader": {
          "type": "header",
          "text": "Server Configuration",
          "size": 5
        },
        "url": {
          "type": "text",
          "label": "ntfy Server URL",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "help": "Default: https://ntfy.sh",
          "placeholder": "https://ntfy.sh",
          "validator": "data.url === '' || /^https?:\\/\\/.+/.test(data.url)"
        },
        "defaultTopic": {
          "type": "text",
          "label": "Default Topic",
          "xs": 12,
          "sm": 12,
          "md": 6,
          "lg": 4,
          "xl": 4,
          "help": "Default topic for notifications"
        },
        "_authHeader": {
          "type": "header",
          "text": "Authentication",
          "size": 5,
          "newLine": true
        },
        "authType": {
          "type": "select",
          "label": "Authentication Type",
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 3,
          "xl": 3,
          "options": [
            { "label": "None", "value": "none" },
            { "label": "Username / Password", "value": "user" },
            { "label": "Access Token", "value": "token" }
          ],
          "default": "none"
        },
        "user": {
          "type": "text",
          "label": "Username",
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 3,
          "xl": 3,
          "hidden": "data.authType !== 'user'"
        },
        "pass": {
          "type": "password",
          "label": "Password",
          "xs": 12,
          "sm": 12,
          "md": 4,
          "lg": 3,
          "xl": 3,
          "hidden": "data.authType !== 'user'"
        },
        "token": {
          "type": "password",
          "label": "Access Token",
          "xs": 12,
          "sm": 12,
          "md": 8,
          "lg": 6,
          "xl": 6,
          "hidden": "data.authType !== 'token'"
        }
      }
    },
    "topicsTab": {
      "type": "panel",
      "label": "Topics",
      "items": {
        "_topicsInfo": {
          "type": "staticText",
          "text": "Configure topics to subscribe to. The adapter will receive messages from these topics in real-time via SSE (Server-Sent Events).",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "style": {
            "marginBottom": 16
          }
        },
        "topics": {
          "type": "table",
          "label": "Subscribed Topics",
          "xs": 12,
          "sm": 12,
          "md": 12,
          "lg": 12,
          "xl": 12,
          "items": [
            {
              "type": "text",
              "attr": "topic",
              "title": "Topic Name",
              "width": "50%",
              "filter": false,
              "sort": false
            },
            {
              "type": "text",
              "attr": "displayName",
              "title": "Display Name",
              "width": "50%",
              "filter": false,
              "sort": false
            }
          ]
        }
      }
    }
  }
}
